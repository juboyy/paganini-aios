{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/agents",
      "regex": "^/agents(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/agents(?:/)?$"
    },
    {
      "page": "/capabilities",
      "regex": "^/capabilities(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/capabilities(?:/)?$"
    },
    {
      "page": "/fund",
      "regex": "^/fund(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/fund(?:/)?$"
    },
    {
      "page": "/guardrails",
      "regex": "^/guardrails(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/guardrails(?:/)?$"
    },
    {
      "page": "/memory",
      "regex": "^/memory(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/memory(?:/)?$"
    },
    {
      "page": "/pipeline",
      "regex": "^/pipeline(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/pipeline(?:/)?$"
    },
    {
      "page": "/settings",
      "regex": "^/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/settings(?:/)?$"
    },
    {
      "page": "/symphony",
      "regex": "^/symphony(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/symphony(?:/)?$"
    },
    {
      "page": "/telemetry",
      "regex": "^/telemetry(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/telemetry(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}
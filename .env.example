# PAGANINI AIOS — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env

# LLM Provider (BYOK — you keep your keys)
# Uncomment ONE provider:
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AI...

# pgvector (used by docker-compose)
PGVECTOR_PASSWORD=changeme

# Dashboard (optional)
PAGANINI_HOST=0.0.0.0
PAGANINI_PORT=8000
